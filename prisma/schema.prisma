// Maison Élise — Luxury E-Commerce Database Schema
// 12 хүснэгт: profiles, collections, categories, products, product_variants,
// product_images, carts, cart_items, orders, order_items, addresses,
// waitlists, wishlists, editorial_hotspots

generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────
// PROFILES — Supabase auth.users-тэй холбоотой
// ─────────────────────────────────────────────────
model Profile {
  id        String   @id @db.Uuid // = auth.users.id
  fullName  String?  @map("full_name")
  phone     String?
  vipTier   String   @default("bronze") @map("vip_tier") // bronze | silver | gold
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  orders    Order[]
  carts     Cart[]
  wishlists Wishlist[]
  addresses Address[]

  @@map("profiles")
}

// ─────────────────────────────────────────────────
// COLLECTIONS — брэндийн цуглуулга (Spring 2026, Automne Classique)
// ─────────────────────────────────────────────────
model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  image       String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  products Product[]

  @@map("collections")
}

// ─────────────────────────────────────────────────
// CATEGORIES — бүтээгдэхүүний ангилал (Bags > Handbags)
// Self-referencing: parent_id → categories.id
// ─────────────────────────────────────────────────
model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0) @map("sort_order")

  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────
model Product {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String // "Cyme Mini"
  edition       String? // "Edition Textured Camel"
  description   String?       @db.Text
  details       String?       @db.Text // dimensions, pockets гэх мэт
  materials     String?       @db.Text // "100% Italian calf leather..."
  materialStory String?       @map("material_story") @db.Text // luxury differentiator
  basePrice     Int           @map("base_price") // цент: 55000 = $550
  status        ProductStatus @default(ACTIVE)
  categoryId    String?       @map("category_id")
  collectionId  String?       @map("collection_id")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  category   Category?        @relation(fields: [categoryId], references: [id])
  collection Collection?      @relation(fields: [collectionId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  waitlists  Waitlist[]

  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// ─────────────────────────────────────────────────
// PRODUCT VARIANTS — өнгө бүрт нэг variant
// Inventory: available = stock_quantity - reserved
// ─────────────────────────────────────────────────
model ProductVariant {
  id            String   @id @default(cuid())
  productId     String   @map("product_id")
  sku           String   @unique // "ME-CM-CAMEL"
  attributes    Json     @db.JsonB // {"color": "Camel", "colorHex": "#C4A77D"}
  priceOverride Int?     @map("price_override") // null → product.basePrice ашиглана
  stockQuantity Int      @default(0) @map("stock_quantity")
  reserved      Int      @default(0) // cart-д байгаа тоо
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  wishlists  Wishlist[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────────
// PRODUCT IMAGES
// variant_id nullable → product-level эсвэл variant-level image
// ─────────────────────────────────────────────────
model ProductImage {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  variantId String? @map("variant_id")
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────────
// CARTS — guest (session_id) эсвэл authenticated (user_id)
// ─────────────────────────────────────────────────
model Cart {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  Profile?   @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

// ─────────────────────────────────────────────────
// CART ITEMS
// Unique constraint: нэг cart-д нэг variant нэг удаа л байна
// ─────────────────────────────────────────────────
model CartItem {
  id         String @id @default(cuid())
  cartId     String @map("cart_id")
  variantId  String @map("variant_id")
  quantity   Int    @default(1)
  priceAtAdd Int    @map("price_at_add") // нэмэх үеийн үнэ (цент)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────
// ORDERS
// State machine: PENDING → CONFIRMED → PROCESSING → SHIPPED → DELIVERED
//                                                              ↓
//                                                          REFUNDED
// ─────────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  userId          String      @map("user_id") @db.Uuid
  status          OrderStatus @default(PENDING)
  totalAmount     Int         @map("total_amount") // цент
  paymentIntentId String?     @unique @map("payment_intent_id")
  shippingAddress Json        @map("shipping_address") @db.JsonB // address snapshot
  giftPackaging   Boolean     @default(false) @map("gift_packaging")
  giftNote        String?     @map("gift_note")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  user  Profile     @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  REFUNDED
}

// ─────────────────────────────────────────────────
// ORDER ITEMS — захиалгын үеийн үнэ snapshot хадгална
// ─────────────────────────────────────────────────
model OrderItem {
  id              String @id @default(cuid())
  orderId         String @map("order_id")
  variantId       String @map("variant_id")
  quantity        Int
  priceAtPurchase Int    @map("price_at_purchase") // цент

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────────
// ADDRESSES — хэрэглэгчийн хаягийн дэвтэр
// Order-т shipping_address JSONB-р snapshot хадгална
// ─────────────────────────────────────────────────
model Address {
  id         String   @id @default(cuid())
  userId     String   @map("user_id") @db.Uuid
  label      String? // "Home", "Office"
  fullName   String   @map("full_name")
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String   @map("postal_code")
  country    String
  phone      String?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id])

  @@map("addresses")
}

// ─────────────────────────────────────────────────
// WAITLISTS — exclusive drop-д бүртгүүлэх
// ─────────────────────────────────────────────────
model Waitlist {
  id            String    @id @default(cuid())
  productId     String    @map("product_id")
  email         String
  name          String?
  notifiedAt    DateTime? @map("notified_at") @db.Timestamptz
  priorityScore Int       @default(0) @map("priority_score")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, email]) // давхардал хамгаалалт
  @@map("waitlists")
}

// ─────────────────────────────────────────────────
// WISHLISTS — хэрэглэгчийн хүслийн жагсаалт
// guest: session_id, authenticated: user_id
// ─────────────────────────────────────────────────
model Wishlist {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id")
  variantId String   @map("variant_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    Profile?       @relation(fields: [userId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("wishlists")
}

// ─────────────────────────────────────────────────
// EDITORIAL HOTSPOTS — lookbook зураг дээрх бүтээгдэхүүний цэг
// ─────────────────────────────────────────────────
model EditorialHotspot {
  id            String  @id @default(cuid())
  editorialSlug String  @map("editorial_slug")
  productId     String  @map("product_id")
  positionX     Decimal @map("position_x") @db.Decimal(5, 2) // 0.00–100.00%
  positionY     Decimal @map("position_y") @db.Decimal(5, 2)

  @@map("editorial_hotspots")
}
